---
import Layout from '../../layouts/Layout.astro';
import BookViewer from '../../components/BookViewer';
import { getCollection } from 'astro:content';
import { marked } from 'marked';

const rawChapters = await getCollection('chapters');
const chapters = await Promise.all(
  rawChapters
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (entry) => {
      // Split raw markdown on <!--page--> markers first, then render each page to HTML
      const rawPages = (entry.body ?? '')
        .split(/<!--page-->/i)
        .map((p: string) => p.trim())
        .filter(Boolean);

      const htmlPages = await Promise.all(rawPages.map((p: string) => marked.parse(p)));

      return {
        id: entry.id,
        title: entry.data.title,
        order: entry.data.order,
        content: htmlPages.length > 1 ? htmlPages : (htmlPages[0] ?? ''),
      };
    })
);
---

<Layout title="System Design — EBook Library" description="Read the System Design EBook covering core concepts.">
  <div style="padding: 0.75rem 1rem 0;">

    <!-- Breadcrumb -->
    <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem; color: var(--text-secondary); font-size: 0.9rem;">
      <a href="/" style="color: var(--text-secondary);">📚 Library</a>
      <span>›</span>
      <span style="color: var(--text-primary); font-weight: 600;">System Design</span>
    </div>

    <!-- Book Viewer -->
    <BookViewer client:only="react" chapters={chapters} />

  </div>
</Layout>
